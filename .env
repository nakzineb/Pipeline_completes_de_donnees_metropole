# =================================================================
# VARIABLES D'ENVIRONNEMENT - PROJET VELIB PIPELINE
# =================================================================

# -----------------------------------------------------------------
# AIRFLOW CONFIGURATION
# -----------------------------------------------------------------
# Airflow utilise ces variables pour se configurer
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Image Airflow à utiliser
AIRFLOW_IMAGE_NAME=apache/airflow:2.8.0-python3.11

# Configuration de base
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True

# Configuration de la base de données Airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Mot de passe admin pour l'interface web
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# -----------------------------------------------------------------
# KAFKA CONFIGURATION
# -----------------------------------------------------------------
# Kafka et Zookeeper utilisent ces ports
KAFKA_BROKER_ID=1
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# -----------------------------------------------------------------
# CLICKHOUSE CONFIGURATION
# -----------------------------------------------------------------
CLICKHOUSE_DB=velib_db
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse123

# -----------------------------------------------------------------
# PROJET CONFIGURATION
# -----------------------------------------------------------------
# Timezone
TZ=Europe/Paris

# API Vélib'
VELIB_API_BASE_URL=https://velib-metropole-opendata.smovengo.cloud/opendata/Velib_Metropole

# -----------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------
# - Ne jamais commiter ce fichier avec de vrais mots de passe en production
# - Pour ce projet académique, on utilise des valeurs simples
# - En production, utiliser des secrets managers (Docker secrets, Vault, etc.)